{
  "name": "@rolexjs/local-platform",
  "version": "1.6.1",
  "description": "Local filesystem Platform for RoleX — stores roles in .rolex/ directories",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deepracticex/drizzle": "^0.2.0",
    "@deepracticex/sqlite": "^0.2.0",
    "@issuexjs/node": "^0.2.0",
    "@resourcexjs/node-provider": "^2.14.0",
    "@rolexjs/core": "workspace:~",
    "@rolexjs/system": "workspace:~",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
